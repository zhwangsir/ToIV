# 复制为 deploy/.env(不入库)
# 强随机:python3 -c "import secrets;print(secrets.token_urlsafe(48))"
TOIV_JWT_SECRET=change-me-strong-random-secret
TOIV_ADMIN_EMAIL=admin
TOIV_ADMIN_PASSWORD=admin123
# 前端 API 基址:留空 = 相对路径(与 web 同源,经反代到 /api)
NEXT_PUBLIC_API_BASE=
# 同源部署时 CORS 不触发;如分域可改为公网来源
TOIV_CORS_ORIGINS=*
