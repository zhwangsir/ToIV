# ToIV API 配置（复制为 .env 后按需修改）
# 逗号分隔的 ComfyUI worker 列表。P0 单实例；P2 起每张 GPU 一个进程时填多个：
#   TOIV_COMFY_WORKERS=http://192.168.71.100:8001,http://192.168.71.100:8002,...
TOIV_COMFY_WORKERS=http://192.168.71.100:8000
TOIV_DEFAULT_CKPT=DreamShaper_8_pruned.safetensors
TOIV_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TOIV_REQUEST_TIMEOUT=30.0
