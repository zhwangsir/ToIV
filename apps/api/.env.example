# ToIV API 配置（复制为 .env 后按需修改；.env 不入库）
# 逗号分隔的 ComfyUI worker 列表。P0 单实例；P2 起每张 GPU 一个进程时填多个：
#   TOIV_COMFY_WORKERS=http://192.168.71.100:8001,http://192.168.71.100:8002,...
TOIV_COMFY_WORKERS=http://192.168.71.100:8000
TOIV_DEFAULT_CKPT=DreamShaper_8_pruned.safetensors
TOIV_CORS_ORIGINS=http://localhost:3100,http://127.0.0.1:3100

# 鉴权：生产务必设置一个高强度随机值
TOIV_JWT_SECRET=change-me-to-a-random-32+-byte-secret

# 启动时引导管理员账号（二者皆非空：不存在则建，存在则提升为 admin）
TOIV_ADMIN_EMAIL=admin@toiv.ai
TOIV_ADMIN_PASSWORD=set-a-strong-password-here
